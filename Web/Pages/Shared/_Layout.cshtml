<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Incidencias</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { padding-bottom: 60px; }
        .navbar-brand { font-weight: bold; }
        footer { position: fixed; bottom: 0; width: 100%; background-color: #343a40; color: white; text-align: center; padding: 10px; }
        .badge-rol { font-size: 0.75rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Gestión de Incidencias</a>
            <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
                @if (Context.Session.GetString("Nombre") != null)
                {
                    <span class="text-white">
                        Hola, <strong>@Context.Session.GetString("Nombre")</strong>
                        <span class="badge bg-secondary badge-rol ms-1">
                            @Context.Session.GetString("Rol")
                        </span>
                    </span>

                    @if (Context.Session.GetString("Rol") == "Admin")
                    {
                        <a href="/Admin/Index" class="btn btn-outline-light btn-sm">Dashboard</a>
                        <a href="/Admin/Usuarios" class="btn btn-outline-light btn-sm">Usuarios</a>
                        <a href="/Admin/Incidencias" class="btn btn-outline-light btn-sm">Incidencias</a>
                    }
                    else if (Context.Session.GetString("Rol") == "Tecnico")
                    {
                        <a href="/Tecnico/Index" class="btn btn-outline-light btn-sm">Panel Técnico</a>
                    }
                    else
                    {
                        <a href="/Usuario/Index" class="btn btn-outline-light btn-sm">Mis Incidencias</a>
                        <a href="/Usuario/Crear" class="btn btn-success btn-sm">+ Nueva</a>
                    }

                    <a href="/Logout" class="btn btn-danger btn-sm">Cerrar sesión</a>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer>
        <small>Sistema de Gestión de Incidencias &copy; 2026 — Campus FP</small>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>