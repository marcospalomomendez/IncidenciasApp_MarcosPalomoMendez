@page
@model Web.Pages.Admin.UsuariosModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestión de Usuarios</h2>
        <a href="/Admin/Index" class="btn btn-secondary">← Volver</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success">@Model.Mensaje</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol actual</th>
                <th>Cambiar rol</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Usuarios)
            {
                <tr>
                    <td>@u.Id</td>
                    <td>@u.Nombre</td>
                    <td>@u.Email</td>
                    <td>
                        <span class="badge
                                @(u.Rol == "Admin" ? "bg-danger" :
                                                            u.Rol == "Tecnico" ? "bg-warning text-dark" : "bg-primary")">
                        @u.Rol
                    </span>
                </td>
                <td>
                    <form method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@u.Id" />
                        <select name="nuevoRol" class="form-select form-select-sm w-auto">
                            <option value="Usuario" selected="@(u.Rol == "Usuario")">Usuario</option>
                            <option value="Tecnico" selected="@(u.Rol == "Tecnico")">Técnico</option>
                            <option value="Admin" selected="@(u.Rol == "Admin")">Admin</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
                    </form>
                </td>
            </tr>
                        }
        </tbody>
    </table>
</div>